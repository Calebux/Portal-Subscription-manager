{
  "manifest_version": 3,
  "name": "SubBot",
  "version": "1.0.0",
  "description": "Your AI subscription manager. Track, audit, and optimize every AI and SaaS subscription — powered by Celo pay-per-run.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "SubBot",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "clipboardWrite",
    "tabs",
    "identity"
  ],
  "host_permissions": [
    "http://localhost:3747/*",
    "https://*.railway.app/*",
    "https://rpc.ankr.com/*",
    "https://api.qrserver.com/*",
    "https://*.web3auth.io/*",
    "https://cdn.jsdelivr.net/*",
    "https://forno.celo.org/*",
    "https://api-auth.web3auth.io/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' https://cdn.jsdelivr.net; object-src 'self';"
  }
}
