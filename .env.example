# Copy to .env and fill in real values. Never commit the real .env file.

PORT=3747
DATA_DIR=                        # defaults to ~/.hermes if unset

# LLM (Nous Research / OpenAI-compatible) — used by llm-analyze.py, negotiate.py
OPENAI_API_KEY=
OPENAI_BASE_URL=https://inference-api.nousresearch.com/v1

# Celo contracts
AGENT_PRIVATE_KEY=               # Celo wallet private key that owns the contracts below
LOG_CONTRACT_ADDRESS=
CREDITS_CONTRACT_ADDRESS=

# Auth — generate long random strings, e.g. `openssl rand -hex 32`
SESSION_SECRET=                  # signs user session tokens (api-bridge.js)
INTERNAL_SERVICE_TOKEN=          # shared secret for negotiate.py / llm-analyze.py calling /log-decision

# Telemetry dashboard
TELEMETRY_KEY=                   # required to read GET /telemetry/stats
